generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  HEAD_LEADER
  MANAGER
  SELLER
  EMPLOYEE
}

enum ContactStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
  FROZEN
}

enum ActivityType {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  MEETING
  TASK
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum StockAlertType {
  MINIMUM
  MAXIMUM
  ZERO
}

enum NotificationType {
  STOCK_MIN
  STOCK_MAX
  STOCK_ZERO
  DEAL_UPDATE
  TASK_DUE
  REQUISITION_UPDATE
  FEEDBACK_RECEIVED
  SYSTEM
}

enum RequisitionCategory {
  PURCHASE
  SYSTEM_IMPROVEMENT
  INFRASTRUCTURE
}

enum RequisitionStatus {
  DRAFT
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LmsCategory {
  PRODUCT_MANUAL
  SALES_TRAINING
  COMPANY_RULES
  OTHER
}

enum PurchaseOrderStatus {
  PENDING
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  RESOLVED
  WAITING
}

enum FiscalNoteType {
  ENTRADA
  SAIDA
}

enum FiscalNoteStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ReceivableStatus {
  PENDING
  RECEIVED
  OVERDUE
  CANCELLED
}

enum BankAccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
}

enum TransactionType {
  IN
  OUT
  TRANSFER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(EMPLOYEE)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  activities          Activity[]
  deals               Deal[]
  notifications       Notification[]
  stockAlertConfig    StockAlertConfig?
  requisitions        Requisition[]
  requisitionComments RequisitionComment[]
  purchaseOrders      PurchaseOrder[]
  learningProgress    LearningProgress[]
  sentFeedbacks       Feedback[]           @relation("SentFeedbacks")
  receivedFeedbacks   Feedback[]           @relation("ReceivedFeedbacks")
  assignedConversations Conversation[]
  sentMessages          Message[]
  flaggedMessages       FlaggedMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model Company {
  id      String  @id @default(cuid())
  name    String
  cnpj    String? @unique
  email   String?
  phone   String?
  city    String?
  state   String?
  website String?

  contacts Contact[]
}

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  whatsapp     String?
  cpf          String?
  cnpj         String?
  razaoSocial  String?
  position     String?
  leadSource   String?
  creditLimit  Float?
  status       ContactStatus @default(LEAD)
  tags         String[]
  notes        String?
  companyId    String?
  customFields Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company       Company?     @relation(fields: [companyId], references: [id])
  deals         Deal[]
  activities    Activity[]
  conversations Conversation[]
  receivables   Receivable[]
}

model Pipeline {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)
  color String @default("#3b82f6")

  deals Deal[]
}

model Deal {
  id            String     @id @default(cuid())
  title         String
  value         Decimal?
  status        DealStatus @default(OPEN)
  pipelineId    String
  contactId     String?
  sellerId      String?
  expectedClose DateTime?
  closedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  pipeline   Pipeline   @relation(fields: [pipelineId], references: [id])
  contact    Contact?   @relation(fields: [contactId], references: [id])
  seller     User?      @relation(fields: [sellerId], references: [id])
  activities Activity[]
  items      DealItem[]
}

model DealItem {
  id        String  @id @default(cuid())
  dealId    String
  productId String
  quantity  Int
  unitPrice Decimal

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  title     String
  content   String?
  contactId String?
  dealId    String?
  userId    String
  dueDate   DateTime?
  completed Boolean      @default(false)
  createdAt DateTime     @default(now())

  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
}

// ─── Estoque ──────────────────────────────────────────────────────────────────

model Supplier {
  id      String  @id @default(cuid())
  name    String
  cnpj    String?
  email   String?
  phone   String?
  contact String?

  products Product[]
}

model ProductCategory {
  id    String @id @default(cuid())
  name  String
  color String @default("#6b7280")

  products Product[]
}

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  description  String?
  barcode      String?
  categoryId   String?
  supplierId   String?
  costPrice    Decimal  @default(0)
  salePrice    Decimal  @default(0)
  unit         String   @default("un")
  currentStock Int      @default(0)
  minStock     Int      @default(0)
  maxStock     Int      @default(100)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  supplier   Supplier?        @relation(fields: [supplierId], references: [id])
  movements  StockMovement[]
  alerts     StockAlert[]
  dealItems  DealItem[]
}

model StockMovement {
  id        String       @id @default(cuid())
  productId String
  type      MovementType
  quantity  Int
  reason    String?
  reference String?
  cost      Decimal?
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model StockAlert {
  id        String         @id @default(cuid())
  productId String
  type      StockAlertType
  value     Int
  triggered Boolean        @default(true)
  sentAt    DateTime?
  createdAt DateTime       @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model StockAlertConfig {
  id     String  @id @default(cuid())
  userId String  @unique
  email  Boolean @default(true)
  push   Boolean @default(true)
  inApp  Boolean @default(true)

  user User @relation(fields: [userId], references: [id])
}

// ─── Notificações ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Requisições ──────────────────────────────────────────────────────────────

model Requisition {
  id          String              @id @default(cuid())
  title       String
  description String?
  category    RequisitionCategory
  status      RequisitionStatus   @default(DRAFT)
  priority    Priority            @default(MEDIUM)
  userId      String
  votes       Int                 @default(0)
  attachments String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  comments      RequisitionComment[]
  purchaseOrder PurchaseOrder?
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  number        String              @unique
  title         String
  supplier      String?
  totalValue    Decimal             @default(0)
  status        PurchaseOrderStatus @default(PENDING)
  requisitionId String?             @unique
  notes         String?
  orderedAt     DateTime?
  receivedAt    DateTime?
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  requisition  Requisition?       @relation(fields: [requisitionId], references: [id])
  createdBy    User               @relation(fields: [createdById], references: [id])
  items        PurchaseOrderItem[]
  fiscalNotes  FiscalNote[]
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  orderId     String
  description String
  quantity    Int           @default(1)
  unit        String        @default("un")
  unitPrice   Decimal       @default(0)

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model RequisitionComment {
  id            String   @id @default(cuid())
  requisitionId String
  userId        String
  content       String
  createdAt     DateTime @default(now())

  requisition Requisition @relation(fields: [requisitionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

// ─── Feedback ─────────────────────────────────────────────────────────────────

model Feedback {
  id              String   @id @default(cuid())
  senderId        String?
  receiverId      String
  content         String
  senderEncrypted String
  anonymous       Boolean  @default(true)
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  sender   User? @relation("SentFeedbacks", fields: [senderId], references: [id])
  receiver User  @relation("ReceivedFeedbacks", fields: [receiverId], references: [id])
}

// ─── LMS ──────────────────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(cuid())
  title       String
  description String?
  category    LmsCategory
  thumbnail   String?
  published   Boolean     @default(false)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())

  lessons  Lesson[]
  progress LearningProgress[]
}

model Lesson {
  id       String  @id @default(cuid())
  courseId String
  title    String
  content  String?
  videoUrl String?
  fileUrl  String?
  order    Int     @default(0)
  duration Int?

  course   Course             @relation(fields: [courseId], references: [id])
  progress LearningProgress[]
}

model LearningProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  lessonId    String?
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User    @relation(fields: [userId], references: [id])
  course Course  @relation(fields: [courseId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])

  @@unique([userId, courseId, lessonId])
}

// ─── WhatsApp / Comunicação ───────────────────────────────────────────────────

model WhatsAppInstance {
  id          String   @id @default(cuid())
  name        String   @unique
  phone       String?
  connected   Boolean  @default(false)
  qrCode      String?  @db.Text
  webhookUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id          String             @id @default(cuid())
  instanceId  String
  remoteJid   String
  contactId   String?
  assignedTo  String?
  status      ConversationStatus @default(OPEN)
  unreadCount Int                @default(0)
  lastMessage String?
  lastMessageAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  instance        WhatsAppInstance @relation(fields: [instanceId], references: [id])
  contact         Contact?         @relation(fields: [contactId], references: [id])
  assignee        User?            @relation(fields: [assignedTo], references: [id])
  messages        Message[]
  flaggedMessages FlaggedMessage[]

  @@unique([instanceId, remoteJid])
}

// ─── Configurações do Sistema ─────────────────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── Permissões de Módulo ─────────────────────────────────────────────────────

model ModulePermission {
  id     String @id @default(cuid())
  module String
  role   Role

  @@unique([module, role])
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model BankAccount {
  id        String          @id @default(cuid())
  name      String
  bank      String?
  agency    String?
  account   String?
  type      BankAccountType @default(CHECKING)
  balance   Decimal         @default(0)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  bills         Bill[]
  receivables   Receivable[]
  transactions  CashTransaction[]
}

model Bill {
  id            String     @id @default(cuid())
  title         String
  description   String?
  amount        Decimal
  dueDate       DateTime
  paidAt        DateTime?
  status        BillStatus @default(PENDING)
  category      String
  supplier      String?
  recurring     Boolean    @default(false)
  bankAccountId String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
}

model Receivable {
  id            String           @id @default(cuid())
  title         String
  description   String?
  amount        Decimal
  dueDate       DateTime
  receivedAt    DateTime?
  status        ReceivableStatus @default(PENDING)
  category      String
  client        String?
  contactId     String?
  bankAccountId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  contact     Contact?     @relation(fields: [contactId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
}

model CashTransaction {
  id            String          @id @default(cuid())
  bankAccountId String
  type          TransactionType
  amount        Decimal
  description   String
  date          DateTime
  category      String?
  createdAt     DateTime        @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
}

model Budget {
  id       String  @id @default(cuid())
  year     Int
  month    Int
  category String
  planned  Decimal @default(0)

  @@unique([year, month, category])
}

// ─── NF-e & Canhoto ───────────────────────────────────────────────────────────

model FiscalNote {
  id             String           @id @default(cuid())
  number         String
  series         String           @default("1")
  type           FiscalNoteType
  status         FiscalNoteStatus @default(PENDING)
  accessKey      String?          @unique
  emitter        String
  recipient      String?
  totalValue     Decimal          @default(0)
  emittedAt      DateTime
  notes          String?
  purchaseOrderId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  canhoto       Canhoto?

  @@unique([number, series, emitter])
}

model Canhoto {
  id           String    @id @default(cuid())
  fiscalNoteId String    @unique
  receivedBy   String
  receivedAt   DateTime
  observations String?
  confirmed    Boolean   @default(true)
  createdAt    DateTime  @default(now())

  fiscalNote FiscalNote @relation(fields: [fiscalNoteId], references: [id], onDelete: Cascade)
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  remoteMessageId String?        @unique
  direction      MessageDirection
  body           String           @db.Text
  type           String           @default("text")
  mediaUrl       String?
  status         MessageStatus    @default(SENT)
  sentBy         String?
  createdAt      DateTime         @default(now())

  conversation    Conversation    @relation(fields: [conversationId], references: [id])
  sender          User?           @relation(fields: [sentBy], references: [id])
  flaggedMessage  FlaggedMessage?
}

// ─── Moderação ────────────────────────────────────────────────────────────────

model FlaggedMessage {
  id             String           @id @default(cuid())
  messageId      String           @unique
  conversationId String
  body           String           @db.Text
  triggeredWords String[]
  direction      MessageDirection
  sentByUserId   String?
  remoteJid      String
  instanceName   String
  notifiedAt     DateTime?
  createdAt      DateTime         @default(now())

  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?        @relation(fields: [sentByUserId], references: [id])
}